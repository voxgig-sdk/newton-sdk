    "/log/{expression}": {
      "get": {
        "summary": "Calculate logarithm",
        "description": "Calculates the logarithm of the provided expression. Format: base|value where base is the logarithm base and value is the number (e.g., 2|8 for log base 2 of 8).",
        "operationId": "logarithm",
        "tags": [
          "Algebra"
        ],
        "parameters": [
          {
            "name": "expression",
            "in": "path",
            "required": true,
            "description": "URL-encoded expression in format base|value (e.g., 2|8 for log base 2 of 8)",
            "schema": {
              "type": "string"
            },
            "example": "2|8"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MathOperationResponse"
                },
                "example": {
                  "operation": "log",
                  "expression": "2|8",
                  "result": "3"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "MathOperationResponse": {
        "type": "object",
        "properties": {
          "operation": {
            "type": "string",
            "description": "The mathematical operation that was performed",
            "example": "derive"
          },
          "expression": {
            "type": "string",
            "description": "The mathematical expression that was processed",
            "example": "x^2"
          },
          "result": {
            "type": "string",
            "description": "The result of the mathematical operation",
            "example": "2 x"
          }
        },
        "required": [
          "operation",
          "expression",
          "result"
        ]
      }
    }
  },
  "tags": [
    {
      "name": "Algebra",
      "description": "Algebraic operations including simplification, factoring, and finding zeros"
    },
    {
      "name": "Calculus",
      "description": "Calculus operations including derivatives, integrals, tangent lines, and area under curves"
    },
    {
      "name": "Trigonometry",
      "description": "Trigonometric functions and their inverses"
    }
  ]
}
