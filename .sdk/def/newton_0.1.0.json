                }
              }
            }
          }
        }
      }
    },
    "/tan/{expression}": {
      "get": {
        "summary": "Calculate tangent",
        "description": "Calculates the tangent of the provided expression.",
        "operationId": "tangentTrig",
        "tags": [
          "Trigonometry"
        ],
        "parameters": [
          {
            "name": "expression",
            "in": "path",
            "required": true,
            "description": "URL-encoded mathematical expression for tangent calculation (e.g., 0)",
            "schema": {
              "type": "string"
            },
            "example": "0"
