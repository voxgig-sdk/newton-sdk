        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MathOperationResponse"
                },
                "example": {
                  "operation": "tan",
                  "expression": "0",
                  "result": "0"
                }
              }
            }
          }
        }
      }
    },
    "/arccos/{expression}": {
      "get": {
        "summary": "Calculate inverse cosine (arccos)",
        "description": "Calculates the inverse cosine (arccosine) of the provided expression.",
        "operationId": "arccos",
        "tags": [
          "Trigonometry"
        ],
        "parameters": [
          {
            "name": "expression",
            "in": "path",
