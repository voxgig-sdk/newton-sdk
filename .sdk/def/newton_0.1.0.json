              "type": "string"
            },
            "example": "pi"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MathOperationResponse"
                },
                "example": {
                  "operation": "cos",
                  "expression": "pi",
                  "result": "-1"
                }
              }
            }
          }
        }
      }
    },
    "/sin/{expression}": {
      "get": {
        "summary": "Calculate sine",
