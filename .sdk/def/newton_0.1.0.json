                "schema": {
                  "$ref": "#/components/schemas/MathOperationResponse"
                },
                "example": {
                  "operation": "arccos",
                  "expression": "1",
                  "result": "0"
                }
              }
            }
          }
        }
      }
    },
    "/arcsin/{expression}": {
